# SMTP 설정 (4단계 메일 발송에서 사용)
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USER=validation-bot@company.com
SMTP_PASSWORD=changeme
SMTP_USE_TLS=true
SMTP_FROM_NAME=Data Validation System

# 저장 경로
DB_PATH=data/validation.db
REPORT_DIR=data/reports

# Fasoo DRM (운영 사내 Windows 전용 — 선택)
# 업로드 파일에 DRM이 걸려 있으면 파싱 전에 자동 해제한다. 그 외 OS/실패 시 no-op.
# 기본 DLL 경로(C:/Windows/System32/f_nxldr.dll)를 바꿔야 할 때만 설정한다.
# FASOO_DLL_PATH=C:/Windows/System32/f_nxldr.dll
